{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    },
    {
      "src": "massenermittlung/frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/ws/(.*)", "dest": "/api/index.py" },
    { "src": "/css/(.*)", "dest": "/massenermittlung/frontend/css/$1" },
    { "src": "/js/(.*)", "dest": "/massenermittlung/frontend/js/$1" },
    { "src": "/dashboard.html", "dest": "/massenermittlung/frontend/dashboard.html" },
    { "src": "/projekt.html", "dest": "/massenermittlung/frontend/projekt.html" },
    { "src": "/index.html", "dest": "/massenermittlung/frontend/index.html" },
    { "src": "/(.*)\\.html", "dest": "/massenermittlung/frontend/$1.html" },
    { "src": "/", "dest": "/massenermittlung/frontend/index.html" }
  ]
}
