{
  "version": 2,
  "builds": [
    {
      "src": "api/extract.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb", "maxDuration": 300 }
    },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/extract.py" },
    { "src": "/css/(.*)", "dest": "/public/css/$1" },
    { "src": "/js/(.*)", "dest": "/public/js/$1" },
    { "src": "/(.*)\\.html", "dest": "/public/$1.html" },
    { "src": "/", "dest": "/public/index.html" }
  ]
}
